{
  "name": "adminpanaderiamatias",
  "version": "1.1.1",
  "description": "Panel de administración interno de Panadería Matías.",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/JavierParedesDev/ActualizacionPanaderiaMatias.git"
  },
  "build": {
    "appId": "com.panaderiamatias.admin",
    "icon": "assets/icon.ico",
    "productName": "Panadería Matías Admin",
    "copyright": "© 2025 Panadería Matías",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Panadería Matías Admin"
    },
    "files": [
      "main.js",
      "preload.js",
      "admin.yml",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/.bin/**/*",
      "!**/scripts/**/*",
      "!**/dist/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "JavierParedesDev",
        "repo": "ActualizacionPanaderiaMati",
        "channel": "admin"
      }
    ]
  },
  "scripts": {
    "start": "set ELECTRON_RUN_AS_NODE=&& npm run build:css && electron .",
    "dev": "set ELECTRON_RUN_AS_NODE=&& npm run build:css && electron .",
    "build:css": "tailwindcss -i ./src/renderer/styles/input.css -o ./src/renderer/styles/output.css --minify",
    "dist": "npm run build:css && electron-builder --win --x64",
    "dist:publish": "npm run build:css && electron-builder --win --x64 --publish always"
  },
  "keywords": [
    "electron",
    "tailwind",
    "panaderia",
    "admin"
  ],
  "author": "Codex",
  "license": "MIT",
  "dependencies": {
    "electron-updater": "^6.8.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  }
}
