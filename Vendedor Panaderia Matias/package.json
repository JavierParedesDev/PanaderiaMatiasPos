{
  "name": "vendedor-panaderia-matias",
  "version": "1.0.6",
  "description": "Terminal de ventas para el personal de PanaderÃ­a MatÃ­as.",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/JavierParedesDev/ActualizacionPanaderiaMatias.git"
  },
  "build": {
    "appId": "com.panaderiamatias.vendedor",
    "productName": "MatÃ­as Ventas",
    "copyright": "Â© 2025 PanaderÃ­a MatÃ­as",
    "asarUnpack": [
      "**/scripts/**/*"
    ],
    "extraResources": [
      {
        "from": "scripts/printer.exe",
        "to": "scripts/printer.exe"
      },
      {
        "from": "src/renderer/assets/logo.png",
        "to": "src/renderer/assets/logo.png"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "artifactName": "vendedor-panaderia-matias-setup-${version}.${ext}",
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MatÃ­as Ventas"
    },
    "files": [
      "main.js",
      "preload.js",
      "cajero.yml",
      "src/**/*",
      "assets/**/*",
      "scripts/**/*",
      "!**/dist/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "JavierParedesDev",
        "repo": "PanaderiaMatiasPos",
        "channel": "cajero"
      }
    ]
  },
  "scripts": {
    "start": "set ELECTRON_RUN_AS_NODE=&& npm run build:css && electron .",
    "dev": "set ELECTRON_RUN_AS_NODE=&& npm run build:css && electron .",
    "build:css": "tailwindcss -i ./src/renderer/styles/input.css -o ./src/renderer/styles/output.css --minify",
    "dist": "npm run build:css && electron-builder --win --x64",
    "dist:publish": "npm run build:css && electron-builder --win --x64 --publish always"
  },
  "keywords": [
    "electron",
    "tailwind",
    "panaderia",
    "ventas"
  ],
  "author": "Codex",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
